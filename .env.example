# Backend API URL (set in Vercel project settings as API_URL — not NEXT_PUBLIC_, keeps IP server-side)
API_URL=http://YOUR_SERVER_IP:8000

# Admin panel password — override this before deploying!
# Start the backend with: ADMIN_KEY=your-secret python3 -m uvicorn scripts.cloud_api:app ...
ADMIN_KEY=osho-admin

# Allowed CORS origins for the backend (comma-separated)
ALLOWED_ORIGINS=https://osho-zeta.vercel.app
