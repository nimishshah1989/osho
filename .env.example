# ─── Frontend (Next.js, PM2 app `osho-frontend`) ──────────────────────

# Backend API base for the /api/* proxy routes. Optional — defaults to
# http://127.0.0.1:8000 (FastAPI on the same VPS, reached over
# loopback). Only set this if the backend ever moves off-box.
# API_URL=http://127.0.0.1:8000

# Offline-PWA corpus — two independent knobs:
#
#   NEXT_PUBLIC_CORPUS_URL — optional auto-download source. When set,
#   the offline banner shows a "Download" button that fetches it
#   directly into the app. Must be a CORS-enabled host. LEAVE UNSET for
#   the file-distribution model (users load the archive from a file
#   instead) — then the banner shows only "Load from file".
#
#   NEXT_PUBLIC_CORPUS_DOWNLOAD_URL — the human-facing download link
#   shown on the /downloadapp page (e.g. a Google Drive share link).
#   This is just a hyperlink a person clicks; no CORS needed. The big
#   file is hosted off-site so nothing large is served from the site.
#
# NEXT_PUBLIC_CORPUS_URL=
NEXT_PUBLIC_CORPUS_DOWNLOAD_URL=https://drive.google.com/file/d/YOUR_FILE_ID/view

# ─── Backend (FastAPI, systemd unit `osho-backend.service`) ───────────

# Admin panel password — override before deploying. The backend hard-
# fails on startup if OSHO_ENV=production and this is default/missing.
ADMIN_KEY=osho-admin

# Allowed CORS origins for the backend (comma-separated).
ALLOWED_ORIGINS=https://oshoarchives.com
